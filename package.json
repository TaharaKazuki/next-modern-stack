{
  "name": "next-modern-stack",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "bun --filter web dev",
    "dev:api": "bun --filter api start:dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.10",
    "turbo": "2.10.5"
  },
  "overrides": {
    "fast-uri": "3.1.4",
    "sharp": "0.35.3"
  }
}
